---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "tcplot() — a Twin Cities community for data visualization practitioners, enthusiasts, and storytellers.",
  image = "/images/tcplot(colorswithtext).png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:site_name" content="tcplot(Data Visualization Twin Cities)" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8MXL74M46T"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-8MXL74M46T');
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&family=Silkscreen:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-lexend bg-white text-gray-900 min-h-screen flex flex-col">
    <header
      class="sticky top-0 bg-white/95 backdrop-blur-sm border-b border-gray-200"
      style="z-index: 1000;"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <div class="flex-shrink-0">
            <a
              href="/"
              class="text-xl font-silkscreen text-gray-900 hover:text-blue-600 transition-colors"
            >
              <span class="hidden md:inline">tcplot(Data Visualization Twin Cities)</span>
              <span class="md:hidden">tcplot(Data Viz TC)</span>
            </a>
          </div>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex space-x-8">
            <!-- Upcoming Events Dropdown -->
            <div class="relative group">
              <button class="text-gray-700 hover:text-blue-600 transition-colors font-medium flex items-center space-x-1">
                <span>Upcoming Events</span>
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute left-0 top-full pt-2 w-56 hidden group-hover:block z-50">
                <div class="rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5">
                  <div class="py-1">
                    <a href="/data-physicalization" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 transition-colors">
                      Data You Can Hold
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <!-- Past Events Dropdown -->
            <div class="relative group">
              <button class="text-gray-700 hover:text-blue-600 transition-colors font-medium flex items-center space-x-1">
                <span>Past Events</span>
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute left-0 top-full pt-2 w-56 hidden group-hover:block z-50">
                <div class="rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5">
                  <div class="py-1">
                    <a href="/claude-code" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 transition-colors">
                      Claude Code
                    </a>
                    <a href="/api-build-a-thon" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 transition-colors">
                      API Build-a-thon
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <a
              href="/member-projects"
              class="text-gray-700 hover:text-blue-600 transition-colors font-medium"
            >
              Member Projects
            </a>
          </nav>

          <!-- Mobile menu button -->
          <div class="md:hidden">
            <button
              id="mobile-menu-button"
              class="text-gray-700 hover:text-blue-600 focus:outline-none focus:text-blue-600"
            >
              <svg
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"
                />
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col space-y-2">
            <!-- Upcoming Events -->
            <div>
              <button id="mobile-upcoming-toggle" class="text-gray-700 hover:text-blue-600 transition-colors font-medium py-2 flex items-center justify-between w-full">
                <span>Upcoming Events</span>
                <svg id="mobile-upcoming-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="mobile-upcoming-menu" class="hidden pl-4 space-y-2 mt-2">
                <a href="/data-physicalization" class="block text-gray-700 hover:text-blue-600 transition-colors py-2">
                  Data You Can Hold
                </a>
              </div>
            </div>
            <!-- Past Events -->
            <div>
              <button id="mobile-past-toggle" class="text-gray-700 hover:text-blue-600 transition-colors font-medium py-2 flex items-center justify-between w-full">
                <span>Past Events</span>
                <svg id="mobile-past-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="mobile-past-menu" class="hidden pl-4 space-y-2 mt-2">
                <a href="/claude-code" class="block text-gray-700 hover:text-blue-600 transition-colors py-2">
                  Claude Code
                </a>
                <a href="/api-build-a-thon" class="block text-gray-700 hover:text-blue-600 transition-colors py-2">
                  API Build-a-thon
                </a>
              </div>
            </div>
            <a
              href="/member-projects"
              class="text-gray-700 hover:text-blue-600 transition-colors font-medium py-2"
            >
              Member Projects
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-gray-50 border-t border-gray-200">
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center text-gray-500"
      >
        <p class="font-medium text-gray-700 mb-2">
          tcplot(Data Visualization Twin Cities) &mdash; Minneapolis&ndash;St. Paul
        </p>
        <div class="flex justify-center gap-6 mb-4">
          <a
            href="https://www.instagram.com/tcplot/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 hover:underline"
          >
            Instagram
          </a>
          <a
            href="https://www.meetup.com/tcplot/?eventOrigin=home_groups_you_organize"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 hover:underline"
          >
            Meetup
          </a>
        </div>
        <p class="text-sm text-gray-400">
          tcplot() is a project by Claire Nyquist. For more, visit <a href="https://clairenyquist.com" class="text-blue-600 hover:underline">clairenyquist.com</a>.
        </p>
      </div>
    </footer>

    <script>
      document
        .getElementById("mobile-menu-button")
        ?.addEventListener("click", () => {
          const menu = document.getElementById("mobile-menu");
          menu?.classList.toggle("hidden");
        });

      document
        .getElementById("mobile-upcoming-toggle")
        ?.addEventListener("click", () => {
          document.getElementById("mobile-upcoming-menu")?.classList.toggle("hidden");
          document.getElementById("mobile-upcoming-icon")?.classList.toggle("rotate-180");
        });

      document
        .getElementById("mobile-past-toggle")
        ?.addEventListener("click", () => {
          document.getElementById("mobile-past-menu")?.classList.toggle("hidden");
          document.getElementById("mobile-past-icon")?.classList.toggle("rotate-180");
        });
    </script>
  </body>
</html>
