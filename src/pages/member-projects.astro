---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Member Projects | tcplot(Data Visualization Twin Cities)"
    description="Data visualization projects from tcplot() community members."
>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="max-w-4xl mx-auto mt-8 mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">
                Member Projects
            </h2>

            <p class="text-lg text-gray-600 leading-relaxed mb-8">
                Contact <a href="mailto:clairenyquist@gmail.com" class="text-blue-600 hover:underline">clairenyquist@gmail.com</a> to have your project featured here!
            </p>

            <ul class="space-y-6 text-gray-600">
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">&#x25B8;</span>
                    <span>
                        <a
                            href="https://teacherpaymn.com"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline font-semibold"
                            >teacherpaymn.com</a
                        > · <a
                            href="https://dev.teacherpaymn.com"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline font-semibold"
                            >dev.teacherpaymn.com</a
                        >
                    </span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">&#x25B8;</span>
                    <span>
                        <a
                            href="https://docs.google.com/spreadsheets/d/1Rb399z3TguKPlqTACHG86qwlzJNMx2a-OSwq_ATBkHM/edit?gid=0#gid=0"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline font-semibold"
                            >Wild Dye Plants</
                        >
                    </span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">&#x25B8;</span>
                    <span>
                        <a
                            href="https://clairenyquist.com"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline font-semibold"
                            >clairenyquist.com</a
                        >
                    </span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">&#x25B8;</span>
                    <span>
                        <a
                            href="https://sgornick.medium.com"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline font-semibold"
                            >sgornick.medium.com</a
                        >
                    </span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">&#x25B8;</span>
                    <span>
                        <a
                            href="https://github.com/orbitalturtle"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline font-semibold"
                            >github.com/orbitalturtle</a
                        >
                    </span>
                </li>
            </ul>
        </div>
    </div>
</Layout>
