---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Member Projects | tcplot(Data Visualization Twin Cities)"
    description="Data visualization projects from tcplot() community members."
>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="max-w-4xl mx-auto mt-8 mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">
                Member Projects
            </h2>

            <ul class="space-y-6 text-gray-600">
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">&#x25B8;</span>
                    <span>
                        <a
                            href="https://teacherpaymn.com"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline font-semibold"
                            >teacherpaymn.com</a
                        > — Interactive visualizations of teacher salaries across Minnesota school districts.
                    </span>
                </li>
            </ul>
        </div>
    </div>
</Layout>
